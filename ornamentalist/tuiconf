#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = ["textual"]
# ///
"""
tuiconf — interactive TUI for configuring argparse-based CLI commands.

Discovers parameters by parsing --help output, renders an interactive
form, and prints the constructed command to stdout on accept.
Optimised for ornamentalist's structured help format but works with
any argparse CLI that uses argument groups.

Usage:
    ./tuiconf <command> [args...]
    ./tuiconf python examples/cli.py
    ./tuiconf uv run python my_script.py

Keybindings:
    j/k, arrows   Navigate between parameters and groups
    enter          Edit a parameter / expand or collapse a group
    esc            Cancel edit (if editing) / quit (if navigating)
    ctrl+d         Accept — exit and print the command to stdout
    q              Quit without output

Text editing (readline):
    ctrl+a/e       Jump to start / end of line
    ctrl+b/f       Move cursor left / right
    ctrl+k/u       Kill to end / start of line
    ctrl+w         Delete word backward
    ctrl+d         Delete character at cursor

Sweep support:
    Enter comma-separated values in a text field (e.g. "1, 2, 3")
    or select multiple choices to generate a parameter sweep.
"""

import dataclasses
import re
import shlex
import subprocess
import sys

from rich.text import Text as RichText
from textual.app import App, ComposeResult
from textual.containers import VerticalScroll
from textual.screen import Screen
from textual.widgets import Static

# ── Types ────────────────────────────────────────────────────


@dataclasses.dataclass
class Param:
    group: str
    name: str
    type: str  # "int", "float", "bool", "str"
    nullable: bool
    choices: list[str] | None
    default: str | None
    required: bool
    value: str


@dataclasses.dataclass
class ParamGroup:
    name: str
    description: str
    params: list[Param]


# ── Theme ────────────────────────────────────────────────────

PURPLE = "rgb(150,75,220)"
DEEP_BLUE = "rgb(20,55,192)"
MAGENTA = "rgb(178,79,226)"
LAVENDER = "rgb(205,215,245)"
CYAN = "rgb(158,241,235)"

# ── Help output parser ───────────────────────────────────────


def parse_help(help_text: str) -> list[ParamGroup]:
    lines = help_text.replace("\x08", "").split("\n")
    groups: list[ParamGroup] = []
    current: ParamGroup | None = None

    i = 0
    while i < len(lines):
        line = lines[i]

        # Group header: "name:" at column 0 (skip "options:", "usage:")
        m = re.match(r"^([\w][\w_-]*):$", line)
        if m and m.group(1) not in ("options", "usage"):
            desc = ""
            if (
                i + 1 < len(lines)
                and lines[i + 1].strip()
                and not re.match(r"^\s+--", lines[i + 1])
            ):
                desc = lines[i + 1].strip()
            current = ParamGroup(name=m.group(1), description=desc, params=[])
            groups.append(current)
            i += 1
            continue

        # Param flag: "  --group.param ..."
        m = re.match(r"^\s+--([\w.]+)", line)
        if m and m.group(1) != "help" and current is not None:
            full_name = m.group(1)
            dot = full_name.find(".")
            param_name = full_name[dot + 1 :] if dot >= 0 else full_name

            # Collect continuation lines (heavily indented)
            desc = ""
            while i + 1 < len(lines) and re.match(r"^\s{16,}", lines[i + 1]):
                i += 1
                desc += " " + lines[i].strip()
            desc = desc.strip()

            # Parse "Type: <type>"
            ptype = "str"
            nullable = False
            tm = re.search(r"Type:\s*([\w\s|]+?)(?:\s*,|\s*\()", desc)
            if tm:
                raw = tm.group(1).strip()
                if "|" in raw and "none" in raw.lower():
                    nullable = True
                    inner = next(
                        (
                            s.strip()
                            for s in raw.split("|")
                            if s.strip().lower() != "none"
                        ),
                        "str",
                    )
                    ptype = inner if inner in ("int", "float") else "str"
                else:
                    ptype = raw if raw in ("int", "float", "bool") else "str"

            # Parse "choices: (val1, val2, ...)"
            choices = None
            cm = re.search(r"choices:\s*\(([^)]+)\)", desc)
            if cm:
                choices = [s.strip().strip("'\"") for s in cm.group(1).split(",")]

            # Parse "(required)" vs "(optional)"
            required = "(required)" in desc

            # Parse "default=..."
            default = None
            dm = re.search(r"default=(.+)$", desc)
            if dm:
                default = dm.group(1).strip()

            current.params.append(
                Param(
                    group=current.name,
                    name=param_name,
                    type=ptype,
                    nullable=nullable,
                    choices=choices,
                    default=default,
                    required=required,
                    value=default or "",
                )
            )

        i += 1

    return groups


# ── Helpers ──────────────────────────────────────────────────


def get_values(param: Param) -> list[str]:
    if not param.value:
        return []
    return [s.strip() for s in param.value.split(",") if s.strip()]


def compute_grid_size(groups: list[ParamGroup]) -> int:
    size = 1
    for g in groups:
        for p in g.params:
            n = len(get_values(p))
            if n > 1:
                size *= n
    return size


def has_sweep(groups: list[ParamGroup]) -> bool:
    return any(len(get_values(p)) > 1 for g in groups for p in g.params)


def build_command_args(
    target_cmd: list[str], groups: list[ParamGroup]
) -> list[str]:
    args = list(target_cmd)
    for g in groups:
        for p in g.params:
            vals = get_values(p)
            if not vals and not p.required:
                continue
            if len(vals) == 1 and vals[0] == (p.default or "") and not p.required:
                continue
            args.append(f"--{g.name}.{p.name}")
            args.extend(vals)
    return args


def type_label(param: Param) -> str:
    if param.choices:
        return f"Literal[{', '.join(param.choices)}]"
    if param.nullable:
        return f"{param.type} | None"
    return param.type


def validate(groups: list[ParamGroup]) -> str | None:
    for g in groups:
        for p in g.params:
            if p.required and not p.value.strip():
                return f"{g.name}.{p.name} is required"
    return None


# ── Help Screen ─────────────────────────────────────────────

